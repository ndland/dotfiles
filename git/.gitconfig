[includeIf "gitdir:~/code/personal/"]
  path = ~/.gitconfig-personal

[includeIf "gitdir:~/code/work/"]
  path = ~/.gitconfig-work

[core]
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only --syntax-theme=Dracula

[gpg]
  format = ssh
  program = gpg

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
  allowedSignersFile = 

[commit]
  gpgSign = true

[alias]
  lg = log --graph --decorate --oneline --all --pretty=format:'%C(auto)%h %d %s %C(blue)<%an> %C(green)(%cr)'

[tag]
  forceSignAnnotated = false

[delta]
  syntax-theme = Dracula
  line-numbers = true
  side-by-side = true
  navigate = true
  dark = true

[diff]
	tool = nvimdiff

[difftool]
	prompt = false
	trustExitCode = true

[difftool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$REMOTE"

[merge]
	tool = nvimdiff
	conflictstyle = zdiff3

[mergetool]
	prompt = false
	keepBackup = false

[mergetool "nvimdiff"]
	cmd = nvim -d "$LOCAL" "$MERGED" "$REMOTE" "$BASE"
	trustExitCode = true
